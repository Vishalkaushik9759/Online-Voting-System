{
  "info": {
    "name": "SecureVote Demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"voter@vote.local\",\n  \"password\": \"Password123!\"\n}" }
      }
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register",
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"new@vote.local\",\n  \"password\": \"Password123!\",\n  \"fullName\": \"New Voter\",\n  \"role\": \"VOTER\",\n  \"zoneId\": \"zone-north\"\n}" }
      }
    },
    {
      "name": "Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/users/me"
      }
    },
    {
      "name": "Voting Dashboard",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/vote/dashboard"
      }
    },
    {
      "name": "Cast Vote",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/vote/cast",
        "body": { "mode": "raw", "raw": "{\n  \"electionId\": \"election-2026\",\n  \"candidateId\": \"replace-with-candidate-id\"\n}" }
      }
    },
    {
      "name": "Admin Users",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/admin/users"
      }
    },
    {
      "name": "Zones",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/zones"
      }
    }
  ]
}
